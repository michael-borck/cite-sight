  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@michaelborck/cite-sight-core": "^0.2.15",
    "chalk": "^5.4.0",
    "commander": "^13.0.0"
