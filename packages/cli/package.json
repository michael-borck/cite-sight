{
  "name": "cite-sight",
  "version": "0.2.15",
  "description": "CLI tool for checking academic references and citations",
  "type": "module",
  "license": "MIT",
  "author": "Michael Borck",
  "repository": {
    "type": "git",
    "url": "https://github.com/michael-borck/cite-sight.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "academic",
    "integrity",
    "citations",
    "references",
    "cli",
    "verification"
  ],
  "bin": {
