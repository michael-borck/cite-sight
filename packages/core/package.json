{
  "name": "@michaelborck/cite-sight-core",
  "version": "0.2.15",
  "description": "Core analysis library for CiteSight academic integrity checking",
  "type": "module",
  "license": "MIT",
  "author": "Michael Borck",
  "repository": {
    "type": "git",
    "url": "https://github.com/michael-borck/cite-sight.git",
    "directory": "packages/core"
  },
  "keywords": [
    "academic",
    "integrity",
    "citations",
    "references",
    "verification",
    "apa",
    "mla",
    "chicago"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "mammoth": "^1.9.0",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitest": "^4.1.0"
  }
}
