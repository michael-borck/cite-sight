{
  "name": "cite-sight",
  "private": true,
  "version": "0.2.8",
  "description": "Academic integrity tool for checking student assignments",
  "workspaces": [
    "packages/core",
    "packages/desktop",
    "packages/cli",
    "packages/server",
    "packages/web"
  ],
  "scripts": {
    "build:core": "npm run build -w packages/core",
    "build:desktop": "npm run build -w packages/desktop",
    "build:cli": "npm run build -w packages/cli",
    "build:server": "npm run build -w packages/server",
    "build:web": "npm run build -w packages/web",
    "build": "npm run build:core && npm run build:desktop && npm run build:cli && npm run build:server && npm run build:web",
    "dev:desktop": "npm run dev -w packages/desktop",
    "dev:web": "npm run dev -w packages/web",
    "dev:server": "npm run dev -w packages/server",
    "dev:core": "npm run dev -w packages/core",
    "lint": "eslint packages/*/src/**/*.ts packages/*/src/**/*.tsx"
  },
  "devDependencies": {
    "typescript": "~5.8.3"
  }
}
